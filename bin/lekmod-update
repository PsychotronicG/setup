#!/usr/bin/env bash

REPO="EnormousApplePie/Lekmod"
BRANCH="main"
VERSION_FILE="${HOME}/.setup/.lekmod_version"
STEAM_PATHS=(
  "${HOME}/.steam/debian-installation/steamapps/common/Sid Meier's Civilization V"
  "${HOME}/.steam/steam/steamapps/common/Sid Meier's Civilization V"
  "${HOME}/.local/share/Steam/steamapps/common/Sid Meier's Civilization V"
)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

find_game_dir() {
  for path in "${STEAM_PATHS[@]}"; do
    [[ -d "$path" ]] && echo "$path" && return 0
  done
  return 1
}

get_installed_version() {
  [[ -f "$VERSION_FILE" ]] && cat "$VERSION_FILE"
}

get_latest_sha() {
  curl -sf "https://api.github.com/repos/${REPO}/commits/${BRANCH}" \
    | grep '"sha"' | head -1 | cut -d'"' -f4 | cut -c1-7
}

cmd_check() {
  local installed latest
  installed=$(get_installed_version)
  latest=$(get_latest_sha)

  if [[ -z "$latest" ]]; then
    echo -e "${RED}✗${NC}  Could not reach GitHub API"
    return 1
  fi

  echo -e "${BOLD}Installed:${NC} ${installed:-none}"
  echo -e "${BOLD}Latest:${NC}    ${latest} (${BRANCH})"

  if [[ "$installed" == "$latest" ]]; then
    echo -e "${GREEN}✓${NC}  Already up to date"
  else
    echo -e "${YELLOW}!${NC}  Update available"
    echo -e "   Run ${BOLD}lekmod-update install${NC} to update"
  fi
}

cmd_install() {
  local latest installed game_dir dlc_dir maps_dir tmp_dir

  installed=$(get_installed_version)
  latest=$(get_latest_sha)

  if [[ -z "$latest" ]]; then
    echo -e "${RED}✗${NC}  Could not reach GitHub API"
    return 1
  fi

  if [[ "$installed" == "$latest" ]]; then
    echo -e "${GREEN}✓${NC}  Already up to date (${latest})"
    return 0
  fi

  game_dir=$(find_game_dir)
  if [[ -z "$game_dir" ]]; then
    echo -e "${RED}✗${NC}  Civ 5 not found. Is the game installed?"
    for p in "${STEAM_PATHS[@]}"; do echo "     $p"; done
    return 1
  fi
  dlc_dir="$game_dir/Assets/DLC"
  maps_dir="$game_dir/Assets/Maps"

  echo -e "${BLUE}→${NC}  Downloading LekMod (${BRANCH}@${latest})..."

  tmp_dir=$(mktemp -d)
  trap 'rm -rf "$tmp_dir"' EXIT

  if ! curl -sfL "https://api.github.com/repos/${REPO}/zipball/${BRANCH}" \
       -o "${tmp_dir}/lekmod.zip"; then
    echo -e "${RED}✗${NC}  Download failed"
    return 1
  fi

  echo -e "${BLUE}→${NC}  Extracting..."
  unzip -q "${tmp_dir}/lekmod.zip" -d "${tmp_dir}/extracted"

  local lekmod_src lekmap_src
  lekmod_src=$(find "${tmp_dir}/extracted" -maxdepth 3 -type d -iname "LEKMOD" | head -1)
  lekmap_src=$(find "${tmp_dir}/extracted" -maxdepth 3 -type d -iname "Lekmap" | head -1)

  if [[ -z "$lekmod_src" ]]; then
    echo -e "${RED}✗${NC}  Could not find LEKMOD folder inside zip"
    return 1
  fi

  # Install LEKMOD → Assets/DLC/
  find "$dlc_dir" -maxdepth 1 -type d -iname "LEKMOD*" -exec rm -rf {} + 2>/dev/null || true
  local dlc_dest="${dlc_dir}/LEKMOD_${latest}"
  mkdir -p "$dlc_dir"
  cp -r "$lekmod_src" "$dlc_dest"

  if [[ -f "${dlc_dest}/linux_ui_check.sh" ]]; then
    echo -e "${BLUE}→${NC}  Running UI check..."
    bash "${dlc_dest}/linux_ui_check.sh"
  fi

  echo -e "${GREEN}✓${NC}  LekMod installed"
  echo -e "   ${dlc_dest}"

  # Install Lekmap → Assets/Maps/
  if [[ -n "$lekmap_src" ]]; then
    find "$maps_dir" -maxdepth 1 -type d -iname "Lekmap*" -exec rm -rf {} + 2>/dev/null || true
    local maps_dest="${maps_dir}/Lekmap_${latest}"
    mkdir -p "$maps_dir"
    cp -r "$lekmap_src" "$maps_dest"
    echo -e "${GREEN}✓${NC}  Lekmap installed"
    echo -e "   ${maps_dest}"
  else
    echo -e "${YELLOW}!${NC}  Lekmap not found in zip — skipping"
  fi

  echo "$latest" > "$VERSION_FILE"
}

cmd_help() {
  echo -e "${BOLD}lekmod-update${NC} — LekMod + Lekmap auto-updater for Civ 5"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo "  lekmod-update check     check for updates"
  echo "  lekmod-update install   download and install latest from ${BRANCH}"
  echo "  lekmod-update help      show this help"
  echo ""
  echo -e "${BOLD}Tracks:${NC} ${REPO}@${BRANCH}"
  echo -e "${BOLD}Version file:${NC} ${VERSION_FILE}"
}

case "$1" in
  check)            cmd_check ;;
  install)          cmd_install ;;
  help|--help|-h)   cmd_help ;;
  *)                cmd_check ;;
esac
