#!/usr/bin/env bash

SEEK_DIR="${HOME}/.setup/seek"
RECENT_FILE="${SEEK_DIR}/recent"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

CODE_EXTS=(py js ts jsx tsx c cpp h hpp rs go java rb sh bash zsh yaml yml json toml lua vim css html)

# ── helpers ──────────────────────────────────────────────────────────────────

has() { command -v "$1" &>/dev/null; }

find_root() {
  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null)
  [[ -n "$git_root" ]] && echo "$git_root" || echo "."
}

IGNORE_FILE="${SEEK_DIR}/ignore"

load_ignores() {
  [[ -f "$IGNORE_FILE" ]] || return
  grep -v '^\s*#' "$IGNORE_FILE" | grep -v '^\s*$'
}
export BAT_THEME="Dracula"
export BAT_STYLE="numbers,header-filename,grid"

bat_cmd() {
  if has bat; then echo "bat"
  elif has batcat; then echo "batcat"
  fi
}

bat_preview() {
  local cmd
  cmd=$(bat_cmd)
  if [[ -n "$cmd" ]]; then
    echo "$cmd --color=always --style=${BAT_STYLE} --theme='${BAT_THEME}' --line-range=:300 {}"
  else
    echo "cat {}"
  fi
}

_build_excludes() {
  local excl=(--exclude .git --exclude node_modules)
  while IFS= read -r entry; do
    excl+=(--exclude "$entry")
  done < <(load_ignores)
  echo "${excl[@]}"
}

_build_find_prunes() {
  local prunes=(-not -path '*/.git/*' -not -path '*/node_modules/*')
  while IFS= read -r entry; do
    prunes+=(-not -path "*/${entry}/*")
  done < <(load_ignores)
  echo "${prunes[@]}"
}

list_all_files() {
  local root="${1:-.}"
  if has fd; then
    local excl
    read -ra excl <<< "$(_build_excludes)"
    fd --type f --hidden --follow "${excl[@]}" . "$root" 2>/dev/null
  else
    local prunes
    read -ra prunes <<< "$(_build_find_prunes)"
    find "$root" -type f "${prunes[@]}" 2>/dev/null
  fi
}

list_code_files() {
  local root="${1:-.}"
  if has fd; then
    local excl
    read -ra excl <<< "$(_build_excludes)"
    local exts=()
    for ext in "${CODE_EXTS[@]}"; do exts+=("-e" "$ext"); done
    fd --type f --hidden --follow "${excl[@]}" "${exts[@]}" . "$root" 2>/dev/null
  else
    local prunes
    read -ra prunes <<< "$(_build_find_prunes)"
    find "$root" -type f \( \
      -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.tsx" -o \
      -name "*.c"  -o -name "*.cpp" -o -name "*.h" -o -name "*.hpp" -o \
      -name "*.rs" -o -name "*.go" -o -name "*.java" -o -name "*.rb"  -o \
      -name "*.sh" -o -name "*.bash" -o -name "*.zsh" -o -name "*.lua" \
    \) "${prunes[@]}" 2>/dev/null
  fi
}

open_file() {
  local file="$1" line="${2:-}"
  [[ -z "$file" ]] && return
  local abs
  abs=$(realpath "$file" 2>/dev/null || echo "$file")
  [[ ! -f "$abs" ]] && { echo -e "${RED}File not found:${NC} $file"; return; }
  log_recent "$abs"
  if [[ -n "$line" && "$line" =~ ^[0-9]+$ ]]; then
    "${EDITOR:-nano}" "+${line}" "$abs" < /dev/tty
  else
    "${EDITOR:-nano}" "$abs" < /dev/tty
  fi
}

copy_to_clipboard() {
  local text="$1"
  if has wl-copy; then echo -n "$text" | wl-copy
  elif has xclip; then echo -n "$text" | xclip -selection clipboard
  elif has xsel; then echo -n "$text" | xsel --clipboard --input
  else echo -e "${YELLOW}No clipboard tool found${NC}" >&2; return 1; fi
}

log_recent() {
  local path="$1"
  mkdir -p "$(dirname "$RECENT_FILE")"
  echo "$path" >> "$RECENT_FILE"
}

lang_from_file() {
  case "${1##*.}" in
    py)               echo "python" ;;
    js|mjs|cjs|jsx)   echo "javascript" ;;
    ts)               echo "typescript" ;;
    tsx)              echo "tsx" ;;
    c)                echo "c" ;;
    cpp|cc|cxx|h|hpp) echo "cpp" ;;
    rs)               echo "rust" ;;
    go)               echo "go" ;;
    java)             echo "java" ;;
    rb)               echo "ruby" ;;
    sh|bash|zsh)      echo "bash" ;;
    html|htm)         echo "html" ;;
    css)              echo "css" ;;
    lua)              echo "lua" ;;
    *)                echo "" ;;
  esac
}

# ── file / code browser ───────────────────────────────────────────────────────

browse_files() {
  local mode="${1:-files}"
  local root="${2:-.}"

  local short_root
  short_root=$(echo "$root" | sed "s|${HOME}|~|")

  local prompt header src_fn
  if [[ "$mode" == "code" ]]; then
    prompt="  [code] > "
    header="root: ${short_root}  |  ctrl-t: all files  ctrl-g: grep  ctrl-a: ast  ctrl-y: copy  ctrl-r: recent"
    src_fn="list_code_files"
  else
    prompt="  [files] > "
    header="root: ${short_root}  |  ctrl-t: code only  ctrl-g: grep  ctrl-a: ast  ctrl-y: copy  ctrl-r: recent"
    src_fn="list_all_files"
  fi

  local raw
  raw=$($src_fn "$root" | fzf \
    --ansi \
    --prompt="$prompt" \
    --preview="$(bat_preview)" \
    --preview-window='right:60%:wrap' \
    --header="$header" \
    --height=80% \
    --border=rounded \
    --expect='ctrl-t,ctrl-g,ctrl-a,ctrl-y,ctrl-r,enter'
  )

  [[ -z "$raw" ]] && return

  local key file
  key=$(echo "$raw" | head -1)
  file=$(echo "$raw" | sed -n '2p')

  case "$key" in
    ctrl-t)
      [[ "$mode" == "files" ]] && browse_files "code" "$root" || browse_files "files" "$root"
      ;;
    ctrl-g) browse_grep "" "$root" ;;
    ctrl-a) browse_ast_mode "$root" ;;
    ctrl-y)
      if [[ -n "$file" ]]; then
        local abs
        abs=$(realpath "$file" 2>/dev/null || echo "$file")
        copy_to_clipboard "$abs" && echo -e "${GREEN}✓${NC}  Copied: ${BOLD}${abs}${NC}"
      fi
      ;;
    ctrl-r) cmd_recent ;;
    *)      [[ -n "$file" ]] && open_file "$file" ;;
  esac
}

# ── grep browser ──────────────────────────────────────────────────────────────

browse_grep() {
  local initial="${1:-}"
  local root="${2:-.}"

  if ! has rg; then
    echo -e "${RED}ripgrep (rg) not found.${NC} Install: sudo apt install ripgrep"
    return 1
  fi

  local seed=""
  [[ -n "$initial" ]] && seed=$(rg --line-number --no-heading --color=never --smart-case "$initial" "$root" 2>/dev/null || true)

  local rg_reload
  rg_reload="rg --line-number --no-heading --color=never --smart-case {q} \"$root\" 2>/dev/null || true"

  local raw
  raw=$(echo "${seed}" | fzf \
    --ansi \
    --disabled \
    --query "$initial" \
    --prompt="  [grep] > " \
    --delimiter=':' \
    --bind "change:reload:${rg_reload}" \
    --preview='
      f=$(echo {} | cut -d: -f1)
      l=$(echo {} | cut -d: -f2)
      b=$(command -v bat 2>/dev/null || command -v batcat 2>/dev/null)
      if [[ -f "$f" ]] && [[ -n "$b" ]]; then
        "$b" --color=always --style="$BAT_STYLE" --theme="$BAT_THEME" --highlight-line "$l" "$f" 2>/dev/null
      elif [[ -f "$f" ]]; then
        cat "$f"
      fi
    ' \
    --preview-window='right:60%:wrap' \
    --header='type to search file contents   ctrl-b: back   enter: open at line' \
    --height=80% \
    --border=rounded \
    --expect='ctrl-b,enter'
  )

  [[ -z "$raw" ]] && return

  local key line
  key=$(echo "$raw" | head -1)
  line=$(echo "$raw" | sed -n '2p')

  [[ "$key" == "ctrl-b" ]] && { browse_files "files" "$root"; return; }
  [[ -z "$line" ]] && return

  open_file "$(echo "$line" | cut -d: -f1)" "$(echo "$line" | cut -d: -f2)"
}

# ── ast mode (symbol browser) ────────────────────────────────────────────────

browse_ast_mode() {
  local root="${1:-.}"
  local short_root
  short_root=$(echo "$root" | sed "s|${HOME}|~|")

  local raw
  raw=$(list_code_files "$root" | fzf \
    --ansi \
    --prompt="  [AST] > " \
    --preview="$(bat_preview)" \
    --preview-window='right:60%:wrap' \
    --header="root: ${short_root}  |  enter: browse symbols   ctrl-a: exit ast   ctrl-g: grep   ctrl-y: copy   ctrl-r: recent" \
    --height=80% \
    --border=rounded \
    --expect='ctrl-a,ctrl-g,ctrl-y,ctrl-r,enter'
  )

  [[ -z "$raw" ]] && return

  local key file
  key=$(echo "$raw" | head -1)
  file=$(echo "$raw" | sed -n '2p')

  case "$key" in
    ctrl-a) browse_files "code" "$root" ;;
    ctrl-g) browse_grep "" "$root" ;;
    ctrl-y)
      if [[ -n "$file" ]]; then
        local abs
        abs=$(realpath "$file" 2>/dev/null || echo "$file")
        copy_to_clipboard "$abs" && echo -e "${GREEN}✓${NC}  Copied: ${BOLD}${abs}${NC}"
      fi
      ;;
    ctrl-r) cmd_recent ;;
    *)      [[ -n "$file" ]] && browse_ast_symbols "$file" "$root" ;;
  esac
}

browse_ast_symbols() {
  local file="$1"
  local root="${2:-.}"

  local lang
  lang=$(lang_from_file "$file")

  if [[ -z "$lang" ]]; then
    echo -e "${YELLOW}No language detected for:${NC} $(basename "$file")"
    open_file "$file"
    return
  fi

  local symbols
  symbols=$(python3 "${SEEK_DIR}/symbols.py" "$file" "$lang" 2>/dev/null)

  if [[ -z "$symbols" ]]; then
    echo -e "${YELLOW}No symbols found in $(basename "$file").${NC} Opening directly."
    open_file "$file"
    return
  fi

  local fname
  fname=$(basename "$file")

  local raw
  raw=$(echo "$symbols" | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --prompt="  [AST: ${fname}] > " \
    --preview='
      b=$(command -v bat 2>/dev/null || command -v batcat 2>/dev/null)
      l={3}
      start=$((l > 5 ? l - 5 : 1))
      if [[ -n "$b" ]]; then
        "$b" --color=always --style="$BAT_STYLE" --theme="$BAT_THEME" \
          --highlight-line "$l" --line-range="${start}:" {2} 2>/dev/null
      else
        cat {2}
      fi
    ' \
    --preview-window='right:60%:wrap' \
    --header="${fname}  [${lang}]   ctrl-b: back to files   enter: jump to symbol" \
    --height=80% \
    --border=rounded \
    --expect='ctrl-b,enter'
  )

  [[ -z "$raw" ]] && return

  local key line
  key=$(echo "$raw" | head -1)
  line=$(echo "$raw" | sed -n '2p')

  [[ "$key" == "ctrl-b" ]] && { browse_ast_mode "$root"; return; }
  [[ -z "$line" ]] && return

  open_file "$(echo "$line" | cut -f2)" "$(echo "$line" | cut -f3)"
}

# ── ast browser (pattern search — seek ast CLI) ───────────────────────────────

browse_ast() {
  local target="${1:-}"

  if ! has ast-grep; then
    echo -e "${RED}ast-grep not found.${NC}"
    echo -e "Install: ${BOLD}cargo install ast-grep${NC}"
    echo -e "         ${BOLD}npm install -g @ast-grep/cli${NC}"
    return 1
  fi

  # Detect or pick language
  local lang=""
  if [[ -n "$target" && -f "$target" ]]; then
    lang=$(lang_from_file "$target")
    if [[ -n "$lang" ]]; then
      echo -ne "  ${DIM}Detected language:${NC} ${lang} — use it? [Y/n] "
      read -r confirm </dev/tty
      [[ "$confirm" =~ ^[Nn]$ ]] && lang=""
    fi
  fi

  if [[ -z "$lang" ]]; then
    lang=$(printf 'python\njavascript\ntypescript\nc\ncpp\nrust\ngo\njava\nruby\nbash\nhtml\ncss\nlua\n' | fzf \
      --prompt="  [ast] language > " \
      --height=20 \
      --border=rounded \
      --header="select language"
    )
    [[ -z "$lang" ]] && return
  fi

  echo -e ""
  echo -e "  ${DIM}Metavariables: \$VAR (single node)  \$\$\$ (zero or more)  \$_ (ignore)${NC}"
  echo -e "  ${DIM}Example:  def \$FUNC(\$\$\$)  ·  \$OBJ.method(\$ARG)  ·  if \$COND { \$\$\$ }${NC}"
  echo -ne "  ${BOLD}Pattern${NC}: "
  read -r pattern </dev/tty
  [[ -z "$pattern" ]] && return

  local scope="${target:-.}"
  echo -e "\n${BLUE}→${NC}  Searching..."

  local results
  results=$(sg --pattern "$pattern" --lang "$lang" "$scope" --json 2>/dev/null \
    | python3 -c '
import sys, json
seen = set()
for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        data = json.loads(raw)
        items = data if isinstance(data, list) else [data]
        for m in items:
            f = m.get("file", "")
            start = m.get("range", {}).get("start", {})
            lineno = start.get("line", 0) + 1
            text = m.get("text", "").split("\n")[0].strip()[:60]
            key = f + ":" + str(lineno)
            if key not in seen:
                seen.add(key)
                display = (f + ":" + str(lineno))[:42].ljust(44) + text
                print(display + "\t" + f + "\t" + str(lineno))
    except Exception:
        pass
' 2>/dev/null)

  if [[ -z "$results" ]]; then
    echo -e "${YELLOW}No matches.${NC}"
    return
  fi

  local count
  count=$(echo "$results" | wc -l)
  echo -e "${GREEN}✓${NC}  ${count} match(es)\n"

  local raw
  raw=$(echo "$results" | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --prompt="  [ast:${lang}] > " \
    --preview='
      b=$(command -v bat 2>/dev/null || command -v batcat 2>/dev/null)
      if [[ -n "$b" ]]; then
        "$b" --color=always --style="$BAT_STYLE" --theme="$BAT_THEME" --highlight-line {3} {2} 2>/dev/null
      else
        cat {2}
      fi
    ' \
    --preview-window='right:60%:wrap' \
    --header="pattern: ${pattern}  |  ctrl-b: back   enter: open" \
    --height=80% \
    --border=rounded \
    --expect='ctrl-b,enter'
  )

  [[ -z "$raw" ]] && return

  local key line
  key=$(echo "$raw" | head -1)
  line=$(echo "$raw" | sed -n '2p')

  [[ "$key" == "ctrl-b" ]] && { browse_files; return; }
  [[ -z "$line" ]] && return

  open_file "$(echo "$line" | cut -f2)" "$(echo "$line" | cut -f3)"
}

# ── recent ────────────────────────────────────────────────────────────────────

cmd_recent() {
  if [[ ! -f "$RECENT_FILE" ]] || [[ ! -s "$RECENT_FILE" ]]; then
    echo "No recently opened files."
    return
  fi

  local selection
  selection=$(tac "$RECENT_FILE" \
    | awk '!seen[$0]++' \
    | head -50 \
    | fzf \
      --prompt="  [recent] > " \
      --height=60% \
      --border=rounded \
      --preview="$(bat_preview)" \
      --preview-window='right:60%:wrap' \
      --header='recently opened via seek   enter: open'
  )
  [[ -z "$selection" ]] && return
  [[ ! -f "$selection" ]] && { echo -e "${RED}File no longer exists:${NC} $selection"; return; }
  open_file "$selection"
}

# ── help ──────────────────────────────────────────────────────────────────────

cmd_help() {
  echo -e "${BOLD}seek${NC} — fuzzy file & code search\n"
  echo -e "${BOLD}Usage:${NC}"
  echo "  seek                   browse all files"
  echo "  seek code              browse code files only"
  echo "  seek grep [query]      live content search (ripgrep)"
  echo "  seek ast [file]        AST pattern search (ast-grep)"
  echo "  seek recent            pick from recently opened files"
  echo "  seek [dir]             browse files in a specific directory"
  echo ""
  echo -e "${BOLD}Keys (file / code browser):${NC}"
  echo "  ctrl-t    toggle: all files ↔ code files"
  echo "  ctrl-g    switch to grep (live ripgrep)"
  echo "  ctrl-a    enter AST mode (enter on a file → symbol list)"
  echo "  ctrl-y    copy absolute path to clipboard"
  echo "  ctrl-r    recently opened files"
  echo "  enter     open in \$EDITOR"
  echo ""
  echo -e "${BOLD}Keys (grep):${NC}"
  echo "  type      live ripgrep across all files"
  echo "  ctrl-b    back to file browser"
  echo "  enter     open file at matched line"
  echo ""
  echo -e "${BOLD}Keys (AST mode):${NC}"
  echo "  enter     browse symbols (functions, classes, etc.) in selected file"
  echo "  ctrl-a    exit back to code browser"
  echo "  ctrl-b    back to AST file list (from symbol browser)"
  echo ""
  echo -e "${BOLD}seek ast (pattern search):${NC}"
  echo "  \$VAR      any single expression / node"
  echo "  \$\$\$       zero or more nodes"
  echo "  e.g.  def \$FUNC(\$\$\$)      — any function definition"
  echo "  e.g.  \$OBJ.append(\$VAL)   — any .append() call"
  echo ""
  echo -e "${BOLD}Dependencies:${NC}"
  echo "  required : fzf"
  echo "  enhanced : bat (preview), fd (fast listing), rg (grep mode)"
  echo "  ast mode : sg / ast-grep  →  cargo install ast-grep"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

case "$1" in
  code)           browse_files "code" "${2:-.}" ;;
  grep)           shift; browse_grep "${1:-}" "${2:-.}" ;;
  ast)            shift; browse_ast "$@" ;;
  recent)         cmd_recent ;;
  help|--help|-h) cmd_help ;;
  "")             browse_files "files" "$(find_root)" ;;
  *)
    if [[ -d "$1" ]]; then
      browse_files "files" "$1"
    else
      echo -e "${RED}Unknown:${NC} $1\n"
      cmd_help
      exit 1
    fi
    ;;
esac
