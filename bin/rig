#!/usr/bin/env bash

SETUP_DIR="${HOME}/.setup"
PROFILES_DIR="${SETUP_DIR}/profiles"
TOOLS_DIR="${SETUP_DIR}/tools"
ACTIVE_PROFILE_FILE="${SETUP_DIR}/.active_profile"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

get_active_profile() {
  if [[ -f "$ACTIVE_PROFILE_FILE" ]]; then
    cat "$ACTIVE_PROFILE_FILE"
  else
    echo "base"
  fi
}

get_profile_tools() {
  local profile="$1"
  local profile_file="${PROFILES_DIR}/${profile}.txt"
  if [[ ! -f "$profile_file" ]]; then
    echo -e "${RED}Error:${NC} profile '${profile}' not found" >&2
    return 1
  fi
  grep -v '^\s*#' "$profile_file" | grep -v '^\s*$'
}

load_tool() {
  local tool="$1"
  local tool_file="${TOOLS_DIR}/${tool}.sh"
  if [[ ! -f "$tool_file" ]]; then
    return 1
  fi
  # Unset functions from previous tool load
  unset -f check install 2>/dev/null
  source "$tool_file"
}

cmd_doctor() {
  local profile
  profile=$(get_active_profile)

  echo -e "${BOLD}Profile:${NC} ${profile}"
  echo ""

  local tools
  tools=$(get_profile_tools "$profile") || exit 1

  local installed=0
  local missing=0
  local unknown=0

  while IFS= read -r tool; do
    [[ -z "$tool" ]] && continue
    if ! load_tool "$tool"; then
      echo -e "  ${YELLOW}?${NC}  ${tool} ${YELLOW}(no installer defined)${NC}"
      ((unknown++))
      continue
    fi
    if check 2>/dev/null; then
      echo -e "  ${GREEN}✓${NC}  ${tool}"
      ((installed++))
    else
      echo -e "  ${RED}✗${NC}  ${tool}"
      ((missing++))
    fi
  done <<< "$tools"

  echo ""
  echo -e "  ${GREEN}${installed} installed${NC}  ${RED}${missing} missing${NC}  ${YELLOW}${unknown} unknown${NC}"
  [[ $missing -gt 0 ]] && echo -e "\n  Run ${BOLD}rig install${NC} to install missing tools."
}

cmd_install() {
  local targets=("$@")

  if [[ ${#targets[@]} -eq 0 ]]; then
    local profile
    profile=$(get_active_profile)
    mapfile -t targets < <(get_profile_tools "$profile") || exit 1
  fi

  for tool in "${targets[@]}"; do
    [[ -z "$tool" ]] && continue
    if ! load_tool "$tool"; then
      echo -e "${YELLOW}?${NC}  No installer for '${tool}' — skipping"
      continue
    fi
    if check 2>/dev/null; then
      echo -e "${GREEN}✓${NC}  ${tool} already installed"
    else
      echo -e "${BLUE}→${NC}  Installing ${tool}..."
      if install; then
        echo -e "${GREEN}✓${NC}  ${tool} installed"
      else
        echo -e "${RED}✗${NC}  ${tool} failed to install"
      fi
    fi
  done
}

cmd_profile() {
  local subcmd="$1"
  shift || true

  case "$subcmd" in
    list)
      local active
      active=$(get_active_profile)
      echo -e "${BOLD}Profiles:${NC}"
      for f in "${PROFILES_DIR}"/*.txt; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f" .txt)
        if [[ "$name" == "$active" ]]; then
          echo -e "  ${GREEN}*${NC} ${name}"
        else
          echo "    ${name}"
        fi
      done
      ;;
    use)
      local name="$1"
      if [[ -z "$name" ]]; then
        echo "Usage: rig profile use <name>"
        exit 1
      fi
      if [[ ! -f "${PROFILES_DIR}/${name}.txt" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' not found"
        exit 1
      fi
      echo "$name" > "$ACTIVE_PROFILE_FILE"
      echo -e "${GREEN}✓${NC}  Switched to profile '${name}'"
      ;;
    new)
      local name="${1:-}"
      if [[ -z "$name" ]]; then
        echo -ne "${BOLD}Profile name:${NC} "
        read -r name </dev/tty
      fi
      if [[ -z "$name" ]]; then
        echo "Aborted."
        exit 0
      fi
      local profile_file="${PROFILES_DIR}/${name}.txt"
      if [[ -f "$profile_file" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' already exists"
        exit 1
      fi

      local lines=()
      for f in "${TOOLS_DIR}"/*.sh; do
        [[ -f "$f" ]] || continue
        local tname desc
        tname=$(basename "$f" .sh)
        desc=$(grep '^DESC=' "$f" | cut -d'"' -f2)
        lines+=("${tname}"$'\t'"${desc}")
      done

      local selected
      selected=$(printf '%s\n' "${lines[@]}" | fzf \
        --multi \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --prompt="  [${name}] > " \
        --header="space: select   enter: confirm   esc: cancel" \
        --height=80% \
        --border=rounded \
        --marker="● " \
        --pointer="▶ "
      )

      if [[ -z "$selected" ]]; then
        echo "Aborted."
        exit 0
      fi

      {
        echo "# Profile: ${name}"
        while IFS=$'\t' read -r tname _; do
          echo "$tname"
        done <<< "$selected"
      } > "$profile_file"

      local count
      count=$(echo "$selected" | wc -l)
      echo -e "\n${GREEN}✓${NC}  Profile '${name}' created with ${count} tool(s)"
      echo -e "   Run ${BOLD}rig profile use ${name}${NC} to activate it."
      ;;
    edit)
      local name="${1:-$(get_active_profile)}"
      local profile_file="${PROFILES_DIR}/${name}.txt"
      if [[ ! -f "$profile_file" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' not found"
        exit 1
      fi

      # Load tools currently in the profile
      local current_tools=()
      while IFS= read -r tool; do
        [[ -z "$tool" ]] && continue
        current_tools+=("$tool")
      done < <(get_profile_tools "$name")

      # Build display list: current tools first, then the rest
      local lines=()
      local seen=()
      for tool in "${current_tools[@]}"; do
        local desc=""
        local f="${TOOLS_DIR}/${tool}.sh"
        [[ -f "$f" ]] && desc=$(grep '^DESC=' "$f" | cut -d'"' -f2)
        lines+=("${tool}"$'\t'"${desc}")
        seen+=("$tool")
      done
      for f in "${TOOLS_DIR}"/*.sh; do
        [[ -f "$f" ]] || continue
        local tname
        tname=$(basename "$f" .sh)
        local skip=0
        for s in "${seen[@]}"; do [[ "$s" == "$tname" ]] && { skip=1; break; }; done
        [[ $skip -eq 1 ]] && continue
        local desc
        desc=$(grep '^DESC=' "$f" | cut -d'"' -f2)
        lines+=("${tname}"$'\t'"${desc}")
      done

      # Pre-select the first N items (the current profile tools) on start
      local n=${#current_tools[@]}
      local bind_str="start:first"
      for ((i=1; i<=n; i++)); do
        [[ $i -gt 1 ]] && bind_str+="+down"
        bind_str+="+select"
      done
      [[ $n -gt 0 ]] && bind_str+="+first"

      local selected
      selected=$(printf '%s\n' "${lines[@]}" | fzf \
        --multi \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --prompt="  [${name}] > " \
        --header="space: toggle   enter: save   esc: cancel" \
        --height=80% \
        --border=rounded \
        --marker="● " \
        --pointer="▶ " \
        --bind="$bind_str"
      )

      if [[ -z "$selected" ]]; then
        echo "Aborted."
        exit 0
      fi

      {
        echo "# Profile: ${name}"
        while IFS=$'\t' read -r tname _; do
          echo "$tname"
        done <<< "$selected"
      } > "$profile_file"

      local count
      count=$(echo "$selected" | wc -l)
      echo -e "\n${GREEN}✓${NC}  Profile '${name}' updated (${count} tool(s))"
      ;;
    *)
      echo -e "Usage: rig profile ${BOLD}<list|use|new|edit>${NC}"
      ;;
  esac
}

cmd_help() {
  echo -e "${BOLD}rig${NC} — portable terminal setup manager"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo "  rig doctor                 check installed tools vs active profile"
  echo "  rig install                install all missing tools in active profile"
  echo "  rig install <tool...>      install specific tools"
  echo "  rig profile list           list all profiles"
  echo "  rig profile use <name>     switch active profile"
  echo "  rig profile new            create a new profile interactively"
  echo "  rig profile edit [name]    edit a profile (default: active)"
  echo ""
  echo -e "${BOLD}Setup:${NC} ${SETUP_DIR}"
  echo -e "${BOLD}Active profile:${NC} $(get_active_profile)"
}

case "$1" in
  doctor)   shift; cmd_doctor "$@" ;;
  install)  shift; cmd_install "$@" ;;
  profile)  shift; cmd_profile "$@" ;;
  help|--help|-h) cmd_help ;;
  *) cmd_help ;;
esac
