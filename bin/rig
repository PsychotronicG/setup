#!/usr/bin/env bash

SETUP_DIR="${HOME}/.setup"
PROFILES_DIR="${SETUP_DIR}/profiles"
TOOLS_DIR="${SETUP_DIR}/tools"
ACTIVE_PROFILE_FILE="${SETUP_DIR}/.active_profile"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- OS detection ---

RIG_OS=""
RIG_OS_PRETTY=""
RIG_PKG_MANAGER=""
RIG_PKG_INSTALL=""

_detect_os() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    RIG_OS="macos"
    RIG_OS_PRETTY="macOS"
    RIG_PKG_MANAGER="brew"
    RIG_PKG_INSTALL="brew install"
    export RIG_OS RIG_OS_PRETTY RIG_PKG_MANAGER RIG_PKG_INSTALL
    return
  fi

  if [[ -f /etc/os-release ]]; then
    local id id_like pretty
    id=$(grep    '^ID='          /etc/os-release | cut -d= -f2 | tr -d '"')
    id_like=$(grep '^ID_LIKE='   /etc/os-release | cut -d= -f2 | tr -d '"' 2>/dev/null || true)
    pretty=$(grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2 | tr -d '"' 2>/dev/null || true)
    RIG_OS="$id"
    RIG_OS_PRETTY="${pretty:-$id}"

    _set_pkg_manager() {
      case "$1" in
        ubuntu|debian|linuxmint|pop|kali|raspbian)
          RIG_PKG_MANAGER="apt"; RIG_PKG_INSTALL="sudo apt-get install -y" ;;
        arch|manjaro|endeavouros|garuda|cachyos|artix)
          RIG_PKG_MANAGER="pacman"; RIG_PKG_INSTALL="sudo pacman -S --noconfirm" ;;
        fedora)
          RIG_PKG_MANAGER="dnf"; RIG_PKG_INSTALL="sudo dnf install -y" ;;
        opensuse*|sles)
          RIG_PKG_MANAGER="zypper"; RIG_PKG_INSTALL="sudo zypper install -y" ;;
        *) return 1 ;;
      esac
      return 0
    }

    if ! _set_pkg_manager "$id"; then
      for token in $id_like; do
        _set_pkg_manager "$token" && break
      done
    fi
  fi

  [[ -z "$RIG_PKG_MANAGER" ]] && RIG_PKG_MANAGER="unknown"
  export RIG_OS RIG_OS_PRETTY RIG_PKG_MANAGER RIG_PKG_INSTALL
}

pkg_install() {
  if [[ -z "$RIG_PKG_INSTALL" ]]; then
    echo -e "${RED}✗${NC}  No package manager detected (OS: ${RIG_OS:-unknown})" >&2
    return 1
  fi
  $RIG_PKG_INSTALL "$@"
}
export -f pkg_install

_detect_os

# --- Profile helpers ---

get_active_profile() {
  if [[ -f "$ACTIVE_PROFILE_FILE" ]]; then
    cat "$ACTIVE_PROFILE_FILE"
  else
    echo "base"
  fi
}

get_profile_tools() {
  local profile="$1"
  local profile_file="${PROFILES_DIR}/${profile}.txt"
  if [[ ! -f "$profile_file" ]]; then
    echo -e "${RED}Error:${NC} profile '${profile}' not found" >&2
    return 1
  fi
  grep -v '^\s*#' "$profile_file" | grep -v '^\s*$'
}

load_tool() {
  local tool="$1"
  local tool_file="${TOOLS_DIR}/${tool}.sh"
  if [[ ! -f "$tool_file" ]]; then
    return 1
  fi
  unset -f check install 2>/dev/null
  unset NAME DESC CATEGORY BINARY 2>/dev/null
  source "$tool_file"
}

# --- Profile picker helpers ---

_rig_pick_category() {
  local tmpfile="$1" prompt="${2:-profile}"

  local -A cat_total cat_sel
  for f in "${TOOLS_DIR}"/*.sh; do
    [[ -f "$f" ]] || continue
    local tname cat
    tname=$(basename "$f" .sh)
    cat=$(grep '^CATEGORY=' "$f" | cut -d'"' -f2)
    [[ -z "$cat" ]] && cat="other"
    cat_total[$cat]=$(( ${cat_total[$cat]:-0} + 1 ))
    grep -qx "$tname" "$tmpfile" 2>/dev/null && \
      cat_sel[$cat]=$(( ${cat_sel[$cat]:-0} + 1 ))
  done

  local lines=("__save__"$'\t'"[ ✓  Save profile ]")
  for cat in $(printf '%s\n' "${!cat_total[@]}" | sort); do
    local total=${cat_total[$cat]}
    local sel=${cat_sel[$cat]:-0}
    lines+=("${cat}"$'\t'"${cat}   (${sel} / ${total})")
  done

  local result
  result=$(printf '%s\n' "${lines[@]}" | fzf \
    --delimiter=$'\t' \
    --with-nth=2 \
    --prompt="  [${prompt}] > " \
    --header="enter: open category   esc: cancel" \
    --height=50% \
    --border=rounded \
    --pointer=" " \
  )
  [[ $? -ne 0 ]] && return 1
  echo "$result" | cut -f1
}

_rig_pick_tools_in_category() {
  local category="$1" tmpfile="$2"

  local sel_tools=() unsel_tools=()
  for f in "${TOOLS_DIR}"/*.sh; do
    [[ -f "$f" ]] || continue
    local tname cat
    tname=$(basename "$f" .sh)
    cat=$(grep '^CATEGORY=' "$f" | cut -d'"' -f2)
    [[ -z "$cat" ]] && cat="other"
    [[ "$cat" != "$category" ]] && continue
    if grep -qx "$tname" "$tmpfile" 2>/dev/null; then
      sel_tools+=("$tname")
    else
      unsel_tools+=("$tname")
    fi
  done

  local all_tools=("${sel_tools[@]}" "${unsel_tools[@]}")
  local n_presel=${#sel_tools[@]}

  local lines=()
  for tname in "${all_tools[@]}"; do
    local desc
    desc=$(grep '^DESC=' "${TOOLS_DIR}/${tname}.sh" | cut -d'"' -f2)
    lines+=("○ ${tname}"$'\t'"${desc}")
  done

  local bind_arg="tab:toggle"
  if [[ $n_presel -gt 0 ]]; then
    local preselect="start:pos(1)+select"
    for ((i=2; i<=n_presel; i++)); do
      preselect+="+pos($i)+select"
    done
    preselect+="+pos(1)"
    bind_arg+=",${preselect}"
  fi

  local selected
  selected=$(printf '%s\n' "${lines[@]}" | fzf \
    --multi \
    --sync \
    --delimiter=$'\t' \
    --with-nth=1,2 \
    --prompt="  [${category}] > " \
    --header="tab: toggle   enter: back to categories   esc: back (no changes)" \
    --height=80% \
    --border=rounded \
    --marker="✓ " \
    --pointer=" " \
    --color="marker:10" \
    --bind="$bind_arg"
  )
  [[ $? -ne 0 ]] && return 1

  local tmp2
  tmp2=$(mktemp)
  while IFS= read -r t; do
    [[ -z "$t" ]] && continue
    local f="${TOOLS_DIR}/${t}.sh"
    local cat
    [[ -f "$f" ]] && cat=$(grep '^CATEGORY=' "$f" | cut -d'"' -f2)
    [[ -z "$cat" ]] && cat="other"
    [[ "$cat" == "$category" ]] && continue
    echo "$t"
  done < "$tmpfile" > "$tmp2"

  if [[ -n "$selected" ]]; then
    while IFS=$'\t' read -r display _; do
      echo "${display#○ }"
    done <<< "$selected" >> "$tmp2"
  fi

  mv "$tmp2" "$tmpfile"
}

_rig_profile_picker() {
  local tmpfile="$1" prompt="${2:-profile}"
  while true; do
    local chosen
    chosen=$(_rig_pick_category "$tmpfile" "$prompt")
    [[ $? -ne 0 ]] && return 1
    [[ "$chosen" == "__save__" ]] && return 0
    _rig_pick_tools_in_category "$chosen" "$tmpfile"
  done
}

# --- Core commands ---

cmd_doctor() {
  local profile
  profile=$(get_active_profile)

  echo -e "${BOLD}OS:${NC}      ${RIG_OS_PRETTY} (${RIG_PKG_MANAGER})"
  echo -e "${BOLD}Profile:${NC} ${profile}"

  local tools
  tools=$(get_profile_tools "$profile") || exit 1

  # First pass — collect all tool data so we can group by category
  local -a t_names=() t_cats=() t_statuses=() t_locations=()

  while IFS= read -r tool; do
    [[ -z "$tool" ]] && continue
    t_names+=("$tool")
    if ! load_tool "$tool"; then
      t_cats+=("other"); t_statuses+=("unknown"); t_locations+=("")
      continue
    fi
    t_cats+=("${CATEGORY:-other}")
    if check 2>/dev/null; then
      local binary="${BINARY:-$NAME}"
      local loc
      loc=$(command -v "$binary" 2>/dev/null || command -v "$tool" 2>/dev/null || echo "(installed)")
      t_statuses+=("ok"); t_locations+=("$loc")
    else
      t_statuses+=("missing"); t_locations+=("")
    fi
  done <<< "$tools"

  # Collect unique sorted categories
  local -a cats=()
  for cat in "${t_cats[@]}"; do
    local seen=0
    for c in "${cats[@]:-}"; do [[ "$c" == "$cat" ]] && { seen=1; break; }; done
    [[ $seen -eq 0 ]] && cats+=("$cat")
  done
  IFS=$'\n' cats=($(printf '%s\n' "${cats[@]}" | sort)); unset IFS

  local installed=0 missing=0 unknown=0

  # Second pass — print grouped by category
  for cat in "${cats[@]}"; do
    echo ""
    echo -e "  ${BOLD}${BLUE}${cat}${NC}"
    echo -e "  ${DIM}$(printf '%.0s─' {1..36})${NC}"

    for i in "${!t_names[@]}"; do
      [[ "${t_cats[$i]}" != "$cat" ]] && continue
      local tool="${t_names[$i]}"
      case "${t_statuses[$i]}" in
        ok)
          echo -e "    ${GREEN}✓${NC}  $(printf '%-18s' "$tool") ${DIM}${t_locations[$i]}${NC}"
          ((installed++))
          ;;
        missing)
          echo -e "    ${RED}✗${NC}  $(printf '%-18s' "$tool") ${DIM}(not installed)${NC}"
          ((missing++))
          ;;
        unknown)
          echo -e "    ${YELLOW}?${NC}  $(printf '%-18s' "$tool") ${YELLOW}(no installer)${NC}"
          ((unknown++))
          ;;
      esac
    done
  done

  echo ""
  echo -e "  ${GREEN}${installed} installed${NC}  ${RED}${missing} missing${NC}  ${YELLOW}${unknown} unknown${NC}"
  [[ $missing -gt 0 ]] && echo -e "\n  Run ${BOLD}rig install${NC} to install missing tools."
  return 0
}

cmd_install() {
  local targets=("$@")

  if [[ ${#targets[@]} -eq 0 ]]; then
    local profile
    profile=$(get_active_profile)
    mapfile -t targets < <(get_profile_tools "$profile") || exit 1
  fi

  for tool in "${targets[@]}"; do
    [[ -z "$tool" ]] && continue
    if ! load_tool "$tool"; then
      echo -e "${YELLOW}?${NC}  No installer for '${tool}' — skipping"
      continue
    fi
    if check 2>/dev/null; then
      echo -e "${GREEN}✓${NC}  ${tool} already installed"
    else
      echo -e "${BLUE}→${NC}  Installing ${tool}..."
      if install; then
        echo -e "${GREEN}✓${NC}  ${tool} installed"
      else
        echo -e "${RED}✗${NC}  ${tool} failed to install"
      fi
    fi
  done
}

cmd_profile() {
  local subcmd="$1"
  shift || true

  case "$subcmd" in
    list)
      local active
      active=$(get_active_profile)
      echo -e "${BOLD}Profiles:${NC}"
      for f in "${PROFILES_DIR}"/*.txt; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f" .txt)
        if [[ "$name" == "$active" ]]; then
          echo -e "  ${GREEN}*${NC} ${name}"
        else
          echo "    ${name}"
        fi
      done
      ;;
    use)
      local name="$1"
      if [[ -z "$name" ]]; then
        echo "Usage: rig profile use <name>"
        exit 1
      fi
      if [[ ! -f "${PROFILES_DIR}/${name}.txt" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' not found"
        exit 1
      fi
      echo "$name" > "$ACTIVE_PROFILE_FILE"
      echo -e "${GREEN}✓${NC}  Switched to profile '${name}'"
      ;;
    new)
      local name="${1:-}"
      if [[ -z "$name" ]]; then
        echo -ne "${BOLD}Profile name:${NC} "
        read -r name </dev/tty
      fi
      if [[ -z "$name" ]]; then echo "Aborted."; exit 0; fi
      local profile_file="${PROFILES_DIR}/${name}.txt"
      if [[ -f "$profile_file" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' already exists"; exit 1
      fi

      local tmpfile; tmpfile=$(mktemp)
      if ! _rig_profile_picker "$tmpfile" "$name"; then
        rm -f "$tmpfile"; echo "Aborted."; exit 0
      fi
      local count; count=$(grep -c . "$tmpfile")
      { echo "# Profile: ${name}"; cat "$tmpfile"; } > "$profile_file"
      rm -f "$tmpfile"
      echo -e "\n${GREEN}✓${NC}  Profile '${name}' created with ${count} tool(s)"
      echo -e "   Run ${BOLD}rig profile use ${name}${NC} to activate it."
      ;;
    edit)
      local name="${1:-$(get_active_profile)}"
      local profile_file="${PROFILES_DIR}/${name}.txt"
      if [[ ! -f "$profile_file" ]]; then
        echo -e "${RED}Error:${NC} profile '${name}' not found"; exit 1
      fi

      local tmpfile; tmpfile=$(mktemp)
      get_profile_tools "$name" > "$tmpfile"
      if ! _rig_profile_picker "$tmpfile" "$name"; then
        rm -f "$tmpfile"; echo "Aborted."; exit 0
      fi
      local count; count=$(grep -c . "$tmpfile")
      { echo "# Profile: ${name}"; cat "$tmpfile"; } > "$profile_file"
      rm -f "$tmpfile"
      echo -e "\n${GREEN}✓${NC}  Profile '${name}' updated (${count} tool(s))"
      ;;
    *)
      echo -e "Usage: rig profile ${BOLD}<list|use|new|edit>${NC}"
      ;;
  esac
}

cmd_help() {
  echo -e "${BOLD}rig${NC} — portable terminal setup manager"
  echo -e "${BOLD}OS:${NC}  ${RIG_OS_PRETTY} (${RIG_PKG_MANAGER})"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo "  rig doctor                 check installed tools vs active profile"
  echo "  rig install                install all missing tools in active profile"
  echo "  rig install <tool...>      install specific tools"
  echo "  rig profile list           list all profiles"
  echo "  rig profile use <name>     switch active profile"
  echo "  rig profile new            create a new profile interactively"
  echo "  rig profile edit [name]    edit a profile (default: active)"
  echo ""
  echo -e "${BOLD}Setup:${NC} ${SETUP_DIR}"
  echo -e "${BOLD}Active profile:${NC} $(get_active_profile)"
}

case "$1" in
  doctor)   shift; cmd_doctor "$@" ;;
  install)  shift; cmd_install "$@" ;;
  profile)  shift; cmd_profile "$@" ;;
  help|--help|-h) cmd_help ;;
  *) cmd_help ;;
esac
